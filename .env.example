# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

OPENAI_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
ADMIN_PASSWORD=

# Email notifications (optional — leave blank to disable).
# GMAIL_ADDRESS is the Gmail account that sends the notification.
# GMAIL_APP_PASSWORD is a 16-character App Password (Gmail requires
# 2-Step Verification to be enabled first, then generate one at
# https://myaccount.google.com/apppasswords). Do NOT use your normal
# Gmail password here.
# NOTIFY_EMAIL is who receives the notifications; defaults to
# GMAIL_ADDRESS if left blank.
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
NOTIFY_EMAIL=
